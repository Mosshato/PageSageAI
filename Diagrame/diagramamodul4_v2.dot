// ============================================================
//  Modul 4 — RAG ChromaDB: Seeding / Indexing / Query (corectat)
//  Corectii fata de original:
//   - ADAUGAT pasul de izolare a sectiunii Core CS din README (regex
//     "Core CS" -> "Advanced CS") inainte de chunking
//   - precizat k=4 la similarity search (RAG_TOP_K)
// ============================================================
digraph Modul4 {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=11, nodesep=0.40, ranksep=0.5, compound=true];
  node  [fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  subgraph cluster_seed {
    label="Seeding — run once";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#fbf6e6"; color="#dcc98a";

    s_run   [label="Run createDB.py", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    s_get   [label="GET OSSU README.md\nfrom GitHub", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    s_core  [label="Isolate Core CS section\n(regex Core CS → Advanced CS)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    s_split [label="Split into chunks\n(700 chars, 100 overlap)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    s_emb   [label="Load all-MiniLM-L6-v2\n+ generate embeddings", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    s_pers  [label="Persist to chroma_ossu_db/", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    s_ready [label="DB ready", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];

    s_run -> s_get -> s_core -> s_split -> s_emb -> s_pers -> s_ready;
  }

  subgraph cluster_index {
    label="Indexing — per course";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#eef4fb"; color="#9bbbdd";

    x_recv  [label="Receive output_dir, course_id", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    x_mark  [label="chroma_indexed.marker\nexists?", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
    x_skip  [label="Skip —\nalready indexed", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    x_load  [label="Load all narration JSONs", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    x_split [label="Split & prefix chunks\n[Course id | Page n]", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    x_emb   [label="Embed with all-MiniLM-L6-v2", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    x_add   [label="Add to shared ChromaDB", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    x_wmark [label="Write chroma_indexed.marker", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    x_done  [label="Step 4 complete", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];

    x_recv -> x_mark;
    x_mark -> x_skip [label="Yes"];
    x_mark -> x_load [label="No"];
    x_load -> x_split -> x_emb -> x_add -> x_wmark -> x_done;
  }

  subgraph cluster_query {
    label="Query — student asks";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#eef7ee"; color="#a8d3a8";

    q_ask   [label="Student POST /ask/\n{ question }", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    q_emb   [label="Embed question\nall-MiniLM-L6-v2", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    q_sim   [label="ChromaDB similarity search\ntop-k chunks (k=4)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    q_build [label="Build prompt\ncontext + question", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    q_call  [label="Call gemini-2.5-flash", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    q_ret   [label="Return { answer }\nto frontend", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];

    q_ask -> q_emb -> q_sim -> q_build -> q_call -> q_ret;
  }

  // shared DB relations (dashed, cross-cluster)
  s_pers -> x_add [style=dashed, label="shared DB", constraint=false];
  x_add  -> q_sim [style=dashed, label="shared DB", constraint=false];
}
