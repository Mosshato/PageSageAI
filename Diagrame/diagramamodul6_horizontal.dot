// ============================================================
//  Modul 6 — Quiz Generation + Student Attempt
//  Cele doua clustere stau side-by-side (orizontal),
//  nodurile din fiecare cluster curg vertical (TB).
// ============================================================
digraph Modul6 {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=11, nodesep=0.30, ranksep=0.45, compound=true];
  node  [fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  // Noduri phantom invizibile pentru a forta cele doua clustere side-by-side
  ph_gen [style=invis, width=0, height=0, label=""];
  ph_att [style=invis, width=0, height=0, label=""];
  { rank=same; ph_gen; ph_att }
  ph_gen -> g_start [style=invis, weight=10];
  ph_att -> t_start [style=invis, weight=10];

  subgraph cluster_gen {
    label="Generation — teacher triggers";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#fbf6e6"; color="#dcc98a";

    g_start [label="Teacher POST\ngenerate-quiz/", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    g_rec   [label="Create Quiz record\nstatus: PENDING", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    g_thr   [label="Start daemon thread", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_coll  [label="Collect narration JSONs\nConcat — truncate 40k chars", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_pr    [label="Build Gemini prompt\n(20 MCQ as JSON array)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_llm   [label="Call gemini-2.5-flash", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_parse [label="Parse JSON response", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_valid [label="Valid?\n(>=10 items, 4 opts,\ncorrect_index 0-3)", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
    g_err   [label="status: ERROR", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];
    g_store [label="Truncate to 20 & store\nstatus: READY", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];

    g_start -> g_rec -> g_thr -> g_coll -> g_pr -> g_llm -> g_parse -> g_valid;
    g_valid -> g_err   [label="No"];
    g_valid -> g_store [label="Yes"];
  }

  subgraph cluster_att {
    label="Student Attempt";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#eef7ee"; color="#a8d3a8";

    t_start [label="Student POST\n/quiz/attempt/\n{ answers: [...] }", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    t_valid [label="answers valid?\n(20 ints, 0-3)", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
    t_400   [label="HTTP 400", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];
    t_cmp   [label="Compare answers[i]\nvs correct_index\n(20 questions)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    t_score [label="score =\ncorrect / 20 x 100", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    t_save  [label="Save QuizAttempt\n(new every time)", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    t_ret   [label="Return { score,\ncorrect_count,\ntotal: 20 }", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];

    t_start -> t_valid;
    t_valid -> t_400 [label="No"];
    t_valid -> t_cmp [label="Yes"];
    t_cmp -> t_score -> t_save -> t_ret;
  }

  // Sageata de legatura fara dependenta de rank
  g_store -> t_start [style=dashed, label="quiz READY", lhead=cluster_att, constraint=false];
}
