// ============================================================
//  Modul 1 — Autentificare & Autorizare  (versiune corectata)
//  Corectii fata de original:
//   - path: /api/login/  ->  /api/auth/login/
//   - body include si "role"; validarea verifica si potrivirea rolului
//   - path refresh: /api/token/refresh/  ->  /api/auth/token/refresh/
//   - MECANISM REAL de refresh: proactiv (timer 30s inainte de expirare) +
//     refresh la reload, NU interceptor reactiv "401 -> refresh -> retry"
// ============================================================
digraph Modul1 {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=11, nodesep=0.40, ranksep=0.5];
  node  [fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  login_form [label="User fills Login form", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
  post_login [label="POST /api/auth/login/\n{ email, password, role }", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  valid      [label="Valid credentials\n& role match?", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
  http401    [label="HTTP 401\nInvalid credentials", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];
  issue      [label="Issue access_token (5 min)\n+ refresh_token (1 day)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  store      [label="Frontend stores tokens\nin localStorage", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  readrole   [label="AuthContext reads role\nfrom token payload", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  role       [label="Role?", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
  student    [label="Route to /student/*", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  teacher    [label="Route to /teacher/*", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  protected  [label="ProtectedRoute checks role\non every navigation", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];

  schedule   [label="scheduleRefresh()\ntimer 30s before access_token expiry", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  silent     [label="silentRefresh()\nPOST /api/auth/token/refresh/\n{ refresh }", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  refok      [label="Refresh success?", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
  newtok     [label="Store new access_token\nreschedule refresh", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
  logout     [label="logout()\nClear localStorage → /login", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];

  reload     [label="App reload\n(restore session)", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
  me         [label="GET /api/auth/me\nwith saved token", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
  mevalid    [label="Token still valid?", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
  restore    [label="Restore session\n+ scheduleRefresh", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];

  login_form -> post_login -> valid;
  valid -> http401 [label="No"];
  valid -> issue   [label="Yes"];
  issue -> store -> readrole -> role;
  role -> student [label="student"];
  role -> teacher [label="teacher"];
  student -> protected;
  teacher -> protected;
  protected -> schedule;
  schedule -> silent [label="timer fires"];
  silent -> refok;
  refok -> newtok [label="success"];
  refok -> logout [label="fail"];
  newtok -> schedule [style=dashed, label="loop", constraint=false];

  reload -> me -> mevalid;
  mevalid -> restore [label="Yes"];
  mevalid -> silent  [label="No (expired)"];
  restore -> schedule;
}
