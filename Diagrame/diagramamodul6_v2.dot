// ============================================================
//  Modul 6 — Quiz Generation + Student Attempt (corectat)
//  Corectii fata de original:
//   - ELIMINAT branch-ul "Already attempted? -> HTTP 400": codul NU
//     verifica tentative anterioare; creeaza un QuizAttempt nou de fiecare
//     data. HTTP 400 apare doar pentru format invalid al raspunsurilor.
//   - Generare: "Valid? 20 items" -> accepta >=10 item-uri, apoi trunchiaza
//     la 20 (fiecare cu 4 optiuni, correct_index in 0-3)
// ============================================================
digraph Modul6 {
  rankdir=TB;
  graph [fontname="Helvetica", fontsize=11, nodesep=0.40, ranksep=0.5, compound=true];
  node  [fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  subgraph cluster_gen {
    label="Generation — teacher triggers";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#fbf6e6"; color="#dcc98a";

    g_start [label="Teacher POST generate-quiz/", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    g_rec   [label="Create Quiz record\nstatus: PENDING", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    g_thr   [label="Start daemon thread", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_coll  [label="Collect all narration JSONs\nConcat text — truncate 40 000 chars", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_pr    [label="Build Gemini prompt\n(20 MCQ as JSON array)", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_llm   [label="Call gemini-2.5-flash", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_parse [label="Parse JSON response", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    g_valid [label="Valid? (≥10 items, 4 options,\ncorrect_index in 0-3)", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
    g_err   [label="status: ERROR", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];
    g_store [label="Truncate to 20 & store questions\nstatus: READY", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];

    g_start -> g_rec -> g_thr -> g_coll -> g_pr -> g_llm -> g_parse -> g_valid;
    g_valid -> g_err   [label="No"];
    g_valid -> g_store [label="Yes"];
  }

  subgraph cluster_att {
    label="Student Attempt";
    fontsize=13; fontname="Helvetica-Bold"; style="rounded,filled"; fillcolor="#eef7ee"; color="#a8d3a8";

    t_start [label="Student POST /quiz/attempt/\n{ answers: [...] }", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];
    t_valid [label="answers valid?\n(list of 20 ints, 0-3)", shape=diamond, style=filled, fillcolor="#f5d97a", color="#d6a829"];
    t_400   [label="HTTP 400", shape=box, style="rounded,filled", fillcolor="#f6c1c1", color="#d05757"];
    t_cmp   [label="Compare answers[i] vs correct_index\nfor each of 20 questions", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    t_score [label="score = correct_count / 20 * 100", shape=box, style="rounded,filled", fillcolor="#bcdcf0", color="#3b82c4"];
    t_save  [label="Save QuizAttempt record\n(new attempt every time — no dedup)", shape=box, style="rounded,filled", fillcolor="#d9b8e6", color="#9c4fc4"];
    t_ret   [label="Return { score, correct_count, total: 20 }", shape=ellipse, style=filled, fillcolor="#bfe6cf", color="#4caf50"];

    t_start -> t_valid;
    t_valid -> t_400 [label="No"];
    t_valid -> t_cmp [label="Yes"];
    t_cmp -> t_score -> t_save -> t_ret;
  }

  g_store -> t_start [style=dashed, label="quiz READY", lhead=cluster_att];
}
